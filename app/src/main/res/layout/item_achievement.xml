<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:id="@+id/containerAchievement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivAchievementIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/btn_star_big_on"
            app:tint="#FFD700" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAchievementTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Achievement Title"
                android:textColor="#0D2B45"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAchievementDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description of how to earn this badge."
                android:textColor="#555555"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvUnlockedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Unlocked: 2023-10-01"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivLockStatus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_lock_idle_lock"
            app:tint="#9E9E9E" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>