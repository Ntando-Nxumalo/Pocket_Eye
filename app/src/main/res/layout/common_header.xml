<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="110dp"
    android:background="@drawable/header_rounded_bottom"
    android:paddingTop="32dp">

    <ImageView
        android:id="@+id/btnHeaderHome"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="16dp"
        android:contentDescription="Home/Logo"
        android:src="@drawable/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dashboard"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnHeaderHome"
        app:layout_constraintEnd_toStartOf="@+id/btnHeaderRightAction"
        app:layout_constraintStart_toEndOf="@+id/btnHeaderHome"
        app:layout_constraintTop_toTopOf="@id/btnHeaderHome" />

    <ImageView
        android:id="@+id/btnHeaderRightAction"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="Action"
        android:padding="4dp"
        android:src="@android:drawable/ic_lock_power_off"
        app:layout_constraintBottom_toBottomOf="@id/btnHeaderHome"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnHeaderHome"
        app:tint="@android:color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>