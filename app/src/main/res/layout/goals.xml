<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Extended Green Header Background -->
        <View
            android:id="@+id/headerBackgroundExtended"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/header_rounded_bottom"
            app:layout_constraintTop_toTopOf="parent" />

        <include
            android:id="@+id/headerInclude"
            layout="@layout/common_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingBottom="100dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerInclude">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvGoalCardTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="New Goal"
                            android:textColor="#0D2B45"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- Goal Name -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Goal Name"
                            android:textStyle="bold"
                            android:textColor="#0D2B45" />

                        <EditText
                            android:id="@+id/etGoalName"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/rounded_edittext"
                            android:hint="e.g. Dream House or Monthly Food"
                            android:inputType="text"
                            android:padding="12dp"
                            android:textColor="@android:color/black"
                            android:textColorHint="@android:color/black" />

                        <!-- Category Selector (For Budget Tracking) -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Category (Link for Budget Tracker)"
                            android:textStyle="bold"
                            android:textColor="#0D2B45" />

                        <Spinner
                            android:id="@+id/spGoalCategory"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/rounded_edittext"
                            android:padding="12dp" />

                        <!-- Target Amount (For Savings) -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Savings Target Amount (Total)"
                            android:textStyle="bold"
                            android:textColor="#0D2B45" />

                        <EditText
                            android:id="@+id/etTargetAmount"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/rounded_edittext"
                            android:hint="R 0.00"
                            android:inputType="numberDecimal"
                            android:padding="12dp"
                            android:textColor="@android:color/black"
                            android:textColorHint="@android:color/black" />

                        <!-- Monthly Spending Targets (For Budget) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="16dp"
                            android:baselineAligned="false">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Min Monthly Spend"
                                    android:textStyle="bold"
                                    android:textColor="#0D2B45" />

                                <EditText
                                    android:id="@+id/etMinTargetAmount"
                                    android:layout_width="match_parent"
                                    android:layout_height="56dp"
                                    android:background="@drawable/rounded_edittext"
                                    android:hint="Warning at..."
                                    android:inputType="numberDecimal"
                                    android:padding="12dp"
                                    android:textColor="@android:color/black"
                                    android:textColorHint="@android:color/black" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Max Monthly Spend"
                                    android:textStyle="bold"
                                    android:textColor="#0D2B45" />

                                <EditText
                                    android:id="@+id/etMaxTargetAmount"
                                    android:layout_width="match_parent"
                                    android:layout_height="56dp"
                                    android:background="@drawable/rounded_edittext"
                                    android:hint="Hard Limit"
                                    android:inputType="numberDecimal"
                                    android:padding="12dp"
                                    android:textColor="@android:color/black"
                                    android:textColorHint="@android:color/black" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Current Amount (Savings progress) -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Current Savings"
                            android:textStyle="bold"
                            android:textColor="#0D2B45" />

                        <EditText
                            android:id="@+id/etCurrentAmount"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/rounded_edittext"
                            android:hint="R 0.00"
                            android:inputType="numberDecimal"
                            android:padding="12dp"
                            android:textColor="@android:color/black"
                            android:textColorHint="@android:color/black" />

                        <!-- Save Button -->
                        <Button
                            android:id="@+id/btnSaveGoals"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="24dp"
                            android:background="@drawable/rounded_button"
                            android:backgroundTint="#66BB6A"
                            android:text="Add Goal"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:textAllCaps="false" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Dim Overlay for FAB menu -->
    <View
        android:id="@+id/fabDimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:alpha="0"
        android:elevation="9dp" />

    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:fabAlignmentMode="center"
        app:hideOnScroll="true"
        android:backgroundTint="@color/primary_green">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@android:color/transparent"
            app:elevation="0dp"
            app:itemIconTint="@color/bottom_nav_colors"
            app:itemTextColor="@color/bottom_nav_colors"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />

    </com.google.android.material.bottomappbar.BottomAppBar>

    <!-- Mini FABs for Radial Menu -->
    <LinearLayout
        android:id="@+id/containerHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="invisible"
        android:elevation="11dp"
        app:layout_anchor="@id/fabAddExpense"
        app:layout_anchorGravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_home"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:shadowColor="#000000"
            android:shadowRadius="4" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/miniFabHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabSize="mini"
            android:src="@android:drawable/ic_menu_today"
            app:backgroundTint="@color/primary_blue"
            app:tint="@android:color/white"
            android:contentDescription="@string/nav_home" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/containerExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="invisible"
        android:elevation="11dp"
        app:layout_anchor="@id/fabAddExpense"
        app:layout_anchorGravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_expense"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:shadowColor="#000000"
            android:shadowRadius="4" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/miniFabExpense"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabSize="mini"
            android:src="@android:drawable/ic_menu_add"
            app:backgroundTint="@color/primary_green"
            app:tint="@android:color/white"
            android:contentDescription="@string/nav_expense" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/containerReport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="invisible"
        android:elevation="11dp"
        app:layout_anchor="@id/fabAddExpense"
        app:layout_anchorGravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_report"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:shadowColor="#000000"
            android:shadowRadius="4" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/miniFabReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabSize="mini"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:backgroundTint="@color/primary_green"
            app:tint="@android:color/white"
            android:contentDescription="@string/nav_report" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/containerGoals"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="invisible"
        android:elevation="11dp"
        app:layout_anchor="@id/fabAddExpense"
        app:layout_anchorGravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_goals"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:shadowColor="#000000"
            android:shadowRadius="4" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/miniFabGoals"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabSize="mini"
            android:src="@android:drawable/ic_menu_compass"
            app:backgroundTint="@color/primary_green"
            app:tint="@android:color/white"
            android:contentDescription="@string/nav_goals" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:backgroundTint="@color/primary_green"
        android:src="@android:drawable/ic_input_add"
        app:layout_anchor="@id/bottomAppBar"
        app:tint="@android:color/white"
        android:elevation="12dp"
        android:contentDescription="Menu" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabChatBot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="72dp"
        app:backgroundTint="@color/primary_green"
        android:src="@android:drawable/stat_notify_chat"
        app:fabSize="normal"
        app:tint="@android:color/white"
        android:contentDescription="Chat Bot" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>